rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: saved_landmarks
    // Fields:
    //   - uid: string (required) - Set to 'public'
    //   - name: string (required)
    //   - date: string (required)
    //   - category: string (required)
    //   - history: string (required)
    //   - lat: number (required)
    //   - lng: number (required)
    //   - collectedAt: timestamp (required)

    function isValidLandmark(data) {
      return data.keys().hasAll(['uid', 'name', 'date', 'category', 'history', 'lat', 'lng', 'collectedAt']) &&
             data.uid is string &&
             data.name is string && data.name.size() < 200 &&
             data.date is string && data.date.size() < 100 &&
             data.category is string && data.category.size() < 50 &&
             data.history is string && data.history.size() < 2000 &&
             data.lat is number && data.lng is number &&
             data.collectedAt is timestamp;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    match /saved_landmarks/{landmarkId} {
      // Allow reading if it's the user's own landmark or if it's public
      allow read: if (isAuthenticated() && resource.data.uid == request.auth.uid) || resource.data.uid == 'public';
      
      // Allow creating if authenticated and uid matches, or if it's 'public' (for demo/fallback)
      allow create: if isValidLandmark(request.resource.data) && 
                    ( (isAuthenticated() && request.resource.data.uid == request.auth.uid) || 
                      (request.resource.data.uid == 'public') );
      
      // Allow deleting only if owner
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
  }
}
