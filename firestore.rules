rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: saved_landmarks
    // Fields:
    //   - uid: string (required) - Owner ID
    //   - name: string (required)
    //   - date: string (required)
    //   - category: string (required)
    //   - history: string (required)
    //   - lat: number (required)
    //   - lng: number (required)
    //   - savedAt: timestamp (required)

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidLandmark(data) {
      return data.keys().hasAll(['uid', 'name', 'date', 'category', 'history', 'lat', 'lng', 'savedAt']) &&
             data.uid is string &&
             data.name is string && data.name.size() < 200 &&
             data.date is string && data.date.size() < 100 &&
             data.category is string && data.category.size() < 50 &&
             data.history is string && data.history.size() < 2000 &&
             data.lat is number && data.lng is number;
    }

    match /saved_landmarks/{landmarkId} {
      allow read: if isOwner(resource.data.uid);
      allow create: if isOwner(request.resource.data.uid) && isValidLandmark(request.resource.data);
      allow delete: if isOwner(resource.data.uid);
    }
  }
}
